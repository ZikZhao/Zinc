fn main(args: [strview]) {
    let inst = Derived();
    let base_ref: dyn BaseInterface = &inst;
    std.cout << "Base reference: " << base_ref->foo();
}

interface BaseInterface {
    fn foo(self: &Self) -> i32;
}

class Base implements BaseInterface {
    init() {
        return Self{};
    }
    drop() {
        std.cout << "Base destructor called\n";
    }
    override fn foo(self: &Self) -> i32 {
        return 42;
    }
}

class Derived implements BaseInterface {
    init() {
        return Self{};
    }
    drop() {
        std.cout << "Derived destructor called\n";
    }
    override fn foo(self: &Self) -> i32 {
        return 100;
    }
}

