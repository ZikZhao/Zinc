fn main(args: [strview]) {
    let inst = Derived();
    let base_ref: &Base = inst;
    std.cout << "Base reference: " << base_ref.foo();
}

virtual class Base {
    init() {
        return Self();
    }
    drop() {
        std.cout << "Base destructor called\n";
    }
    virtual fn foo(self: &Self) -> i32 {
        return 42;
    }
}

virtual class Derived extends Base {
    init() {
        return Self();
    }
    drop() {
        std.cout << "Derived destructor called\n";
    }
    override fn foo(self: &Self) -> i32 {
        return 100;
    }
}

