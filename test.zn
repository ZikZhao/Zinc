class A{
    let a: i32;
    init(a: i32, b: i32) {
        return Self{a: a};
    }
    fn foo(self: &mut Self) {
        self.a = 5;
        Self.bar(5);
    }
    static fn bar(a: i32) -> i32 {
        return 1;
    }
}

enum B {
    A,
    C,
}

fn main(args: [strview]) {
    let d = foo(B.A);
}

fn foo(b: B) {
    return;
}
