fn main(args: [strview]) {
    let mut arr: std.vector<dyn I>;
    let mut a1 = A();
    arr.push_back(&a1);
}

interface I {
    fn foo(self: &mut Self, x: i32) -> i32;
}

class A implements I {
    init() {
        return Self{};
    }
    fn foo(self: &mut Self, x: i32) -> i32 {
        return x + 1;
    }
}