fn main() {
    let v1 = Vec3{ x: 1, y: 2, z: 3 };
    let v2 = Vec3{ x: 4, y: 5, z: 6 };
    let v3 = v1 + v2;
    std.print("v3: ({}, {}, {})", v3.x, v3.y, v3.z);
}

class Vec3<T: type> {
    let x: T;
    let y: T;
    let z: T;

    init(x: T, y: T, z: T) {
        return Self{ x: x, y: y, z: z };
    }

    operator+(self: &Self, other: &Self) -> Self {
        return Self{
            x: self.x + other.x,
            y: self.y + other.y,
            z: self.z + other.z,
        };
    }

    operator*(self: &Self, scalar: T) -> Self {
        return Self{
            x: self.x * scalar,
            y: self.y * scalar,
            z: self.z * scalar,
        };
    }
}
