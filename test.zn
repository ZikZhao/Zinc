let x = A<i32>{ a: 42, b: true };

// second
type TypeTest = A<B<i32> >;

type A<T: type> = {
    a: T,
    b: bool,
};

type B<T: type> = T;

type X<v: bool> = i32;

const a = 5;
const b = 10;
const c = 15;
const d = 20;

// third
const is_valid = a < b && c > d;

// last
type weird_inst = X<(b > c)>;

const xyz = std.is_integral::<i32>;