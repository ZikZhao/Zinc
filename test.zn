fn main() -> i32 {
    let x = MyClass<i32>(42);
    return x.method1(10);
}

fn g() -> i32 {
    let x = MyClass<i32>(42);
    return x.method1(10);
}

class MyClass<T: type> {
    let value: T;
    init(self: &Self, value: T) {
        self.value = value;
    }
    fn method1(self: &Self, x: i32) -> T {
        return self.value;
    }
}

fn add<T: type>(a: T, b: T) -> T {
    return a + b;
}

fn max<T: type>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}
