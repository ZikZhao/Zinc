fn main(args: [strview]) {
    let mut a = A();
    let i: dyn I = &a;
    let ptr = i as? *mut A;
    std.cout << (ptr as *mut void);
}

interface I {
    fn foo(self: &mut Self, x: i32) -> i32;
}

class A implements I {
    init() {
        return Self{};
    }
    fn foo(self: &mut Self, x: i32) -> i32 {
        return x + 1;
    }
}