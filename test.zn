fn main() -> i32 {
    let x = MyClass<i32>(42);
    let y = Point { x: 1.0, y: 2.0 };
    return x.method1(10);
}

fn g() -> i32 {
    let x = MyClass<i32>(42);
    return x.method1(10);
}

class MyClass<T: type> {
    let value: T;
    init(value: T) {
        return Self{ value: value };
    }
    fn method1(self: &Self, x: i32) -> T {
        return self.value;
    }
}

fn add<T: type>(a: T, b: T) -> T {
    return a + b;
}

fn max<T: type>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

type Rect = {
    lt: Point,
    rb: Point,
};

type Point = {
    x: f64,
    y: f64,
    z: (f64, f64) -> f64,
    a: *Point,
};
