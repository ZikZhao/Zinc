let a: i8 = 127;

fn add(a: i32, b: i32) -> i32 {
    return a + b;
}

fn sub(a: i32, b: i32) -> i32 { return a - b; }

fn sub(a: f64, b: f64) -> f64 { return a - b; }

let f: (i32, i32) -> i32 = add;

let g = sub;

class Base {
    data: i32;
    data2: f64;
    fn add1() -> i32 {
        return data;
    }
};

class Derived {
    data3: bool;
    fn sub1() -> i32 {
        if (data3) {
            return 1;
        } else {
            return 0;
        }
    }
};

fn main() -> i32 {
    f(2, 3);
    g(5, 4);
    g(3.0, 2.0);
}