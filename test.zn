class A {
    let x: i32;
    init(x: i32) { return Self{ x: x }; }
}

enum B {
    C,
    D,
}

fn main(args: [strview]) {
    let b = B.C;
    switch (b) {
        case B.C: {
            std.print("C");
            break;
        }
        case B.D: {
            std.print("D");
            break;
        }
    }
}

