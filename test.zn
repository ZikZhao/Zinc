fn main() -> i32 {
    let y = MyClass<f64>(3.14);
    let z = y.value2;
    return z.method1(10);
}

class MyClass<T: type> {
    let value: T;
    init(value: T) {
        return Self{ value: value };
    }
    fn method1(self: &Self, x: i32) -> T {
        return self.value;
    }
}

specialize class MyClass<f64> {
    let value: f64;
    let value2: f64;
    init(value: f64) {
        return Self{ value: value };
    }
    fn method1(self: &Self, x: i32) -> f64 {
        return self.value2;
    }
}

fn max<T: type>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}
