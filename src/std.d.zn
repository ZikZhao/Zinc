class string_view {
    type value_type = u8;
    type size_type = usize;
    type difference_type = isize;

    type pointer = *value_type;
    type const_pointer = *value_type;
    type reference = &value_type;
    type const_reference = &value_type;

    class iterator {
        type difference_type = isize;
        type pointer = *value_type;
        type reference = &value_type;

        init();
        init(ptr: pointer);

        operator=(self: &mut Self, other: &Self) -> &mut Self;
        operator*(self: &Self) -> reference;
        operator->(self: &Self) -> pointer;
        operator++(self: &mut Self) -> &mut Self;
        operator--(self: &mut Self) -> &mut Self;
        operator+(self: &Self, n: difference_type) -> Self;
        operator-(self: &Self, n: difference_type) -> Self;
        operator-(self: &Self, other: &Self) -> difference_type;
        operator+=(self: &mut Self, n: difference_type) -> &mut Self;
        operator-=(self: &mut Self, n: difference_type) -> &mut Self;
        operator==(self: &Self, other: &Self) -> bool;
        operator!=(self: &Self, other: &Self) -> bool;
        operator<(self: &Self, other: &Self) -> bool;
        operator<=(self: &Self, other: &Self) -> bool;
        operator>(self: &Self, other: &Self) -> bool;
        operator>=(self: &Self, other: &Self) -> bool;
    }

    type const_iterator = iterator;
    type reverse_iterator = const_iterator;
    type const_reverse_iterator = const_iterator;

    init();
    init(data: const_pointer, size: size_type);
    init<Iter: type>(first: Iter, last: Iter);
    init(first: const_iterator, last: const_iterator);

    fn at(self: &Self, index: size_type) -> value_type;
    operator[](self: &Self, index: size_type) -> value_type;
    fn front(self: &Self) -> value_type;
    fn back(self: &Self) -> value_type;

    fn data(self: &Self) -> const_pointer;
    fn size(self: &Self) -> size_type;
    fn length(self: &Self) -> size_type;
    fn empty(self: &Self) -> bool;

    fn begin(self: &Self) -> const_iterator;
    fn end(self: &Self) -> const_iterator;
    fn cbegin(self: &Self) -> const_iterator;
    fn cend(self: &Self) -> const_iterator;
    fn rbegin(self: &Self) -> const_reverse_iterator;
    fn rend(self: &Self) -> const_reverse_iterator;
    fn crbegin(self: &Self) -> const_reverse_iterator;
    fn crend(self: &Self) -> const_reverse_iterator;

    fn substr(self: &Self, pos: size_type) -> Self;
    fn substr(self: &Self, pos: size_type, count: size_type) -> Self;

    fn find(self: &Self, needle: Self) -> size_type;
    fn find(self: &Self, needle: Self, pos: size_type) -> size_type;
    fn find(self: &Self, needle: const_pointer) -> size_type;
    fn find(self: &Self, needle: const_pointer, pos: size_type) -> size_type;

    operator=(self: &mut Self, other: &Self) -> &mut Self;

    operator==(self: &Self, other: &Self) -> bool;
    operator==(other: const_pointer, self: &Self) -> bool;
    operator==(self: &Self, other: const_pointer) -> bool;
    operator!=(self: &Self, other: &Self) -> bool;
    operator!=(other: const_pointer, self: &Self) -> bool;
    operator!=(self: &Self, other: const_pointer) -> bool;
    operator<(self: &Self, other: &Self) -> bool;
    operator<(other: const_pointer, self: &Self) -> bool;
    operator<(self: &Self, other: const_pointer) -> bool;
    operator<=(self: &Self, other: &Self) -> bool;
    operator<=(other: const_pointer, self: &Self) -> bool;
    operator<=(self: &Self, other: const_pointer) -> bool;
    operator>(self: &Self, other: &Self) -> bool;
    operator>(other: const_pointer, self: &Self) -> bool;
    operator>(self: &Self, other: const_pointer) -> bool;
    operator>=(self: &Self, other: &Self) -> bool;
    operator>=(other: const_pointer, self: &Self) -> bool;
    operator>=(self: &Self, other: const_pointer) -> bool;
}

class string {
    type value_type = u8;
    type size_type = usize;
    type difference_type = isize;

    static let npos: size_type;

    type pointer = *mut value_type;
    type const_pointer = *value_type;
    type reference = &mut value_type;
    type const_reference = &value_type;

    class iterator {
        type difference_type = isize;
