class numeric_limits<T: type> {
    static fn min() -> T;
    static fn max() -> T;
    static fn lowest() -> T;

    static fn epsilon() -> T;
    static fn infinity() -> T;
    static fn quiet_NaN() -> T;
    static fn signaling_NaN() -> T;
}

class unique_ptr<T: type> {
    type element_type = T;
    type pointer = *T;

    init();
    init(ptr: pointer);
    init<U: type>(other: unique_ptr<U>);

    fn get(self: &Self) -> pointer;
    fn release(self: &mut Self) -> pointer;
    fn reset(self: &mut Self);
    fn reset(self: &mut Self, ptr: pointer);

    operator*(self: &Self) -> &T;
    operator*(self: &mut Self) -> &mut T;
    operator->(self: &Self) -> pointer;
    operator->(self: &mut Self) -> *mut T;
    operator=(self: &mut Self, other: &Self) -> &mut Self;
    operator=<U: type>(self: &mut Self, other: unique_ptr<U>) -> &mut Self;
}

class shared_ptr<T: type> {
    type element_type = T;
    type pointer = *T;

    init();
    init(ptr: pointer);
    init(other: &Self);
    init<U: type>(other: shared_ptr<U>);
    init<U: type>(other: unique_ptr<U>);

    fn get(self: &Self) -> pointer;
    fn reset(self: &mut Self);
    fn reset(self: &mut Self, ptr: pointer);
    fn use_count(self: &Self) -> i64;

    operator*(self: &Self) -> &T;
    operator*(self: &mut Self) -> &mut T;
    operator->(self: &Self) -> pointer;
    operator->(self: &mut Self) -> *mut T;
    operator=(self: &mut Self, other: &Self) -> &mut Self;
    operator=<U: type>(self: &mut Self, other: shared_ptr<U>) -> &mut Self;
}

fn make_unique<T: type, Args...: type>(args: Args...) -> unique_ptr<T>;
fn make_shared<T: type, Args...: type>(args: Args...) -> shared_ptr<T>;

class nullopt_t {
    init();
}

let nullopt: nullopt_t;

class optional<T: type> {
    type value_type = T;

    init();
    init(value: nullopt_t);
    init(value: T);
    init(other: Self);

    fn has_value(self: &Self) -> bool;
    fn value(self: &Self) -> &T;
    fn value(self: &mut Self) -> &mut T;
    fn value_or(self: &Self, default_value: T) -> T;

    fn reset(self: &mut Self);
    fn emplace<Args...: type>(self: &mut Self, args: Args...);

    operator*(self: &Self) -> &T;
    operator*(self: &mut Self) -> &mut T;
    operator->(self: &Self) -> *T;
    operator->(self: &mut Self) -> *mut T;
    operator=(self: &mut Self, value: nullopt_t) -> &mut Self;
    operator=(self: &mut Self, value: T) -> &mut Self;
    operator=(self: &mut Self, other: &Self) -> &mut Self;

    operator==(self: &Self, other: &Self) -> bool;
    operator!=(self: &Self, other: &Self) -> bool;
}

fn make_optional<T: type, Args...: type>(args: Args...) -> optional<T>;

