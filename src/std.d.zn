class ratio<Num: usize, Den: usize> {}

namespace chrono {
    class duration<Rep: type, Period: type> {
        type rep = Rep;
        type period = Period;

        init();
        init(count: rep);

        fn count(self: &Self) -> rep;
        fn zero() -> Self;
        fn min() -> Self;
        fn max() -> Self;

        operator=(self: &mut Self, other: &Self) -> &mut Self;

        operator+(self: &Self, other: &Self) -> Self;
        operator-(self: &Self, other: &Self) -> Self;
        operator/(self: &Self, value: rep) -> Self;
        operator/(self: &Self, other: &Self) -> rep;
        operator+=(self: &mut Self, other: &Self) -> &mut Self;
        operator-=(self: &mut Self, other: &Self) -> &mut Self;
        operator/=(self: &mut Self, value: rep) -> &mut Self;

        operator==(self: &Self, other: &Self) -> bool;
        operator==<T: type>(self: &Self, other: &T) -> bool;
        operator!=(self: &Self, other: &Self) -> bool;
        operator!=<T: type>(self: &Self, other: &T) -> bool;
        operator<(self: &Self, other: &Self) -> bool;
        operator<<T: type>(self: &Self, other: &T) -> bool;
        operator<=(self: &Self, other: &Self) -> bool;
        operator<=<T: type>(self: &Self, other: &T) -> bool;
        operator>(self: &Self, other: &Self) -> bool;
        operator><T: type>(self: &Self, other: &T) -> bool;
        operator>=(self: &Self, other: &Self) -> bool;
        operator>=<T: type>(self: &Self, other: &T) -> bool;
    }

    type nanoseconds = duration<i64, ratio<1, 1000000000>>;
    type microseconds = duration<i64, ratio<1, 1000000>>;
    type milliseconds = duration<i64, ratio<1, 1000>>;
    type seconds = duration<i64, ratio<1, 1>>;

    fn duration_cast<ToDuration: type, FromDuration: type>(d: FromDuration) -> ToDuration;

    class time_point<Clock: type> {
        type clock = Clock;
        type duration_type = Clock.duration;

        init();
        init(d: duration_type);

        operator=(self: &mut Self, other: &Self) -> &mut Self;

        fn time_since_epoch(self: &Self) -> duration_type;

        operator+(self: &Self, d: duration_type) -> Self;
        operator-(self: &Self, d: duration_type) -> Self;
        operator-(self: &Self, other: &Self) -> duration_type;

        operator==(self: &Self, other: &Self) -> bool;
        operator!=(self: &Self, other: &Self) -> bool;
        operator<(self: &Self, other: &Self) -> bool;
        operator<=(self: &Self, other: &Self) -> bool;
        operator>(self: &Self, other: &Self) -> bool;
        operator>=(self: &Self, other: &Self) -> bool;
    }

    class steady_clock {
        type duration = chrono.nanoseconds;
        type time_point = chrono.time_point<steady_clock>;

        static fn now() -> time_point;
    }

    class system_clock {
        type duration = chrono.nanoseconds;
        type time_point = chrono.time_point<system_clock>;

        static fn now() -> time_point;
    }

    fn now() -> system_clock.time_point;
}

